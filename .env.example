# Lead Finder Pro — Environment Variables
# Copy this file to `.env` and adjust as needed.

# SQLite database file path.
# This is the only required variable. The database file is created automatically
# on first `bun run db:push`.
DATABASE_URL="file:./db/custom.db"

# Note: API keys for data providers (OpenStreetMap, Geoapify, Foursquare, TomTom,
# Google Maps) are NOT stored in environment variables. They are managed entirely
# through the in-app Settings page and stored in the local SQLite database.
# This means you can change keys at runtime without editing source code or .env.
